/*--------------------SETUP -> INCIO DE PROCESO PRINCIPAL(se ejecuta una vez)------------------------*/
void setup()
{
  // LED RGB PARA VERIFICAR EL ESTADO DEL WIFI
  // EN EL RELE HIGH ES APAGAR Y LOW ENCENDER
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(BUTTON_PIN), FuncionBoton, RISING);
  digitalWrite(RELAY_PIN, LOW);
  // DEFINICION DE COLORES PARA EL LED RGB AL INICIO DEL PROGRAMA O CUANDO NO SE HA CONECTADO A WIFI
  ledcSetup(canal_LED_RED, frec, resolucion);
  ledcSetup(canal_LED_GREEN, frec, resolucion);
  ledcSetup(canal_LED_BLUE, frec, resolucion);
  ledcAttachPin(RGB_RED, canal_LED_RED);
  ledcAttachPin(RGB_GREEN, canal_LED_GREEN);
  ledcAttachPin(RGB_BLUE, canal_LED_BLUE);
  ledcWrite(canal_LED_RED, 255);
  ledcWrite(canal_LED_GREEN, 255);
  ledcWrite(canal_LED_BLUE, 255);
  Serial.begin(115200);
  ledcSetup(canal_buzzer, frec, resolucion);
  SPI.begin();
  rfid.PCD_Init();
  Serial.println("Lector de tarjetas iniciado exitosamente");
  delay(1000);
  // Mostrar el logotipo
  //-----------Iniciar pantalla OLED-------------
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C))
  { // Dirección 0x3D para 128x64
    Serial.println(F("SSD1306 allocation failed"));
    for (;;)
      ; // No continuar, bucle para siempre
  }
  display.clearDisplay();
  display.drawBitmap(0, 0, Logo_bits, Logo_width, Logo_height, WHITE);
  display.display();
  delay(3000);
  Serial.println("Iniciando Conexion");
  //LOGO DE CONECTANDO AL WIFI
  display.clearDisplay();            
  display.setTextColor(WHITE); 
  display.setTextSize(2);        
  display.setCursor(8, 0);            
  display.print(F("Conectando \n"));
  display.drawBitmap( 33, 15, Wifi_start_bits, Wifi_start_width, Wifi_start_height, WHITE);
  display.display();
  Ethernet.init(5);

  IPAddress ip(MYIPADDR);
  IPAddress dns(MYDNS);
  IPAddress gw(MYGW);
  IPAddress sn(MYIPMASK);
  Ethernet.begin(mac, ip, dns, gw, sn);
  Serial.println("Conexion con datos estaticos establecida!");
  display.clearDisplay();
  display.setTextSize(2);             // Escala normal de píxeles 2:2
  display.setTextColor(WHITE);        // Dibujar texto en blanco
  display.setCursor(8, 0);            // Comienza en la esquina superior izquierda
  display.print(F("Conectado \n"));
  display.drawBitmap( 33, 15, Wifi_connected_bits, Wifi_connected_width, Wifi_connected_height, WHITE);
  ethernetConnected = true;
  display.display();
  
  delay(5000);
  // Inicializar NTP
  timeClient.begin();
  timeClient.setTimeOffset(utcOffsetInSeconds);

  Serial.print("IP Local: ");
  Serial.println(Ethernet.localIP());
  Serial.print("Subnet Mask : ");
  Serial.println(Ethernet.subnetMask());
  Serial.print("Gateway IP : ");
  Serial.println(Ethernet.gatewayIP());
  Serial.print("Servidor DNS: ");
  Serial.println(Ethernet.dnsServerIP());
  Serial.println("Ethernet iniciado exitosamente");
}

void leer_mandar(String tarjeta)
{
  String result = "";
  Serial.println("Enviando el ID de la Tarjeta");

  if (client.connect(ip_servidor, puerto_servidor))
  {
    Serial.println("Conectado al servidor");
    String request = String("GET ") + ruta_control_acceso + "?card_uid=" + tarjeta + "&device_token=" + device_uid + " HTTP/1.1\r\n" + "Host: " + ip_servidor + "\r\n" + "Connection: close\r\n\r\n";
    client.print(request);
    while (client.connected() || client.available())
    {
      if (client.available())
      {
        char c = client.read();
        result += c;
      }
    }
    // Cerrar la conexión
    client.stop();
    if (result.startsWith("HTTP/1.1 200 OK"))
    {
      int httpCode = 200;
      int bodyIndex = result.indexOf("\r\n\r\n") + 4;
      if (bodyIndex >= 4)
      {
        result = result.substring(bodyIndex);
        String miRespuesta = result;
        char my_char_array[75];
        result.toCharArray(my_char_array, 75);

        if (httpCode == 200)
        {
          if (miRespuesta.startsWith("Acceso Concedido: "))
          { // COMPROBADO
            int indexador = miRespuesta.indexOf(':');
            String user_name = miRespuesta.substring(indexador + 2);
            Serial.println("Se te ha concedido acceso");
            Serial.println(user_name);
            display.clearDisplay();
            display.setTextSize(2);      
            display.setTextColor(WHITE); 
            display.setCursor(30, 0);    
            display.print(F("Acceso"));
            display.setCursor(12, 20);
            display.print(F("Concedido"));
            display.setTextSize(1);
            display.setCursor(15, 46);
            display.println(user_name);
            display.display();
            ledcWrite(canal_LED_RED, 0);
            ledcWrite(canal_LED_GREEN, 255);
            ledcWrite(canal_LED_BLUE, 0);
            digitalWrite(RELAY_PIN, HIGH);
            tone(BUZZER_PIN, NOTE_G7, 1000, BUZZER_CHANNEL);
            delay(6000); // Reproducir durante 3 segundos
            digitalWrite(RELAY_PIN, LOW);
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 255);
            ledcWrite(canal_LED_BLUE, 255);
            delay(1000);
            Serial.println("Fin acceso concedido");
          }
          else if (miRespuesta.startsWith("Acceso Denegado: "))
          { // COMPROBADO
            int indexador = miRespuesta.indexOf(':');
            String user_name = miRespuesta.substring(indexador + 2);
            Serial.println("Se te nego el acceso");
            Serial.println(user_name);
            Serial.print(F("Acceso Denegado: "));
            Serial.println(user_name);
            display.clearDisplay();
            display.setTextSize(2);      
            display.setTextColor(WHITE); 
            display.setCursor(30, 0);    
            display.print(F("Acceso"));
            display.setCursor(18, 20);
            display.print(F("Denegado "));
            display.setTextSize(1);
            display.setCursor(15, 46);
            display.print(user_name);
            display.display();
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 0);
            ledcWrite(canal_LED_BLUE, 0);
            tone(BUZZER_PIN, NOTE_E4, 500, BUZZER_CHANNEL);
            delay(3000);
            display.clearDisplay();
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 255);
            ledcWrite(canal_LED_BLUE, 255);
            delay(1);
          }
          else if (miRespuesta == "Tarjeta no Encontrada")
          { // COMPROBADO
            Serial.println("No se encontro la tarjeta en la base de datos");
            display.clearDisplay();
            display.setTextSize(2);      
            display.setTextColor(WHITE); 
            display.setCursor(26, 0);    
            display.print(F("Tarjeta"));
            display.setCursor(52, 20);
            display.print(F("No"));
            display.setCursor(4, 40);
            display.print(F("Encontrada"));
            display.display();
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 0);
            ledcWrite(canal_LED_BLUE, 0);
            tone(BUZZER_PIN, NOTE_E4, 500, BUZZER_CHANNEL);
            display.clearDisplay();
            delay(3000);
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 255);
            ledcWrite(canal_LED_BLUE, 255);
          }
          else if (miRespuesta == "Tarjeta Enviada a Servidor")
          { // COMPROBADO
            Serial.println("La tarjeta ya se envio al servidor");
            display.clearDisplay();
            display.setTextSize(2);      
            display.setTextColor(WHITE); 
            display.setCursor(20, 0);    
            display.print(F("Tarjeta "));
            display.setCursor(12, 20);
            display.print(F("Enviada a"));
            display.setCursor(18, 40);
            display.print(F("Servidor"));
            display.display();
            ledcWrite(canal_LED_RED, 238);
            ledcWrite(canal_LED_GREEN, 230);
            ledcWrite(canal_LED_BLUE, 11);
            tone(BUZZER_PIN, NOTE_G7, 500, BUZZER_CHANNEL);
            display.clearDisplay();
            delay(1000);
            ledcWrite(canal_LED_RED, 0);
            ledcWrite(canal_LED_GREEN, 0);
            ledcWrite(canal_LED_BLUE, 0);
          }
          else if (miRespuesta == "Tarjeta Registrada")
          { // COMPROBADO
            Serial.println("Ya se registro la tarjeta");
            display.clearDisplay();
            display.setTextSize(2);      
            display.setTextColor(WHITE); 
            display.setCursor(20, 0);    
            display.print(F("Tarjeta"));
            display.setCursor(4, 20);
            display.print(F("Registrada"));
            display.display();
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 0);
            ledcWrite(canal_LED_BLUE, 0);
            tone(BUZZER_PIN, NOTE_E4, 500, BUZZER_CHANNEL);
            delay(1000);
            display.clearDisplay();
            ledcWrite(canal_LED_RED, 255);
            ledcWrite(canal_LED_GREEN, 255);
            ledcWrite(canal_LED_BLUE, 255);
          }
        }
        char *token = strtok(my_char_array, "\n");
        if (token != NULL)
        {
          token = strtok(NULL, "\r");
          if (token != NULL)
          {
            result = String(token);
          }
        }
        else
        {
          Serial.println("Error: Primer token es NULL");
        }
      }
      else
      {
        Serial.println("Error: Índice del cuerpo es inválido");
      }
    }
    else
    {
      Serial.println("Error: Respuesta HTTP no es 200 OK");
    }
  }
  else
  {
    Serial.println("Error: No se pudo conectar al servidor");
  }
}

void loop()
{
  if (rfid.PICC_IsNewCardPresent())
  {
    if (rfid.PICC_ReadCardSerial())
    {
      MFRC522::PICC_Type piccType = rfid.PICC_GetType(rfid.uid.sak);
      Serial.print("RFID/NFC Tag Type: ");
      Serial.println(rfid.PICC_GetTypeName(piccType));
      Serial.print("UID:");

      for (int i = 0; i < rfid.uid.size; i++)
      {
        CardID += rfid.uid.uidByte[i];
      }
      Serial.println(CardID);
      Serial.println();
      delay(2000);
    }
  }

  if (CardID != "")
  {
    leer_mandar(CardID);
    CardID = "";
  }

  if (botonPresionado == true)
  {
    ledcWrite(canal_LED_RED, 0);
    ledcWrite(canal_LED_GREEN, 255);
    ledcWrite(canal_LED_BLUE, 0);
    digitalWrite(RELAY_PIN, HIGH);
    tone(BUZZER_PIN, NOTE_G7, 1000, BUZZER_CHANNEL);
    delay(6000);
    ledcWrite(canal_LED_RED, 255);
    ledcWrite(canal_LED_GREEN, 255);
    ledcWrite(canal_LED_BLUE, 255);
    digitalWrite(RELAY_PIN, LOW);
    botonPresionado = false;
  }
  timeClient.update();
  String formattedTime = timeClient.getFormattedTime();
  String hourMinute = formattedTime.substring(0, 5);
  
  // Mostrar la hora en la pantalla OLED
  display.clearDisplay();
  display.setTextSize(4);
  display.setTextColor(WHITE);
  display.setCursor(0, 10);
  display.print(hourMinute);
  display.display();

  if (Ethernet.hardwareStatus() == EthernetNoHardware) {
    Serial.println("Modulo ethernet ha fallado");
    ledcWrite(canal_LED_RED, 255);
    ledcWrite(canal_LED_GREEN, 0);
    ledcWrite(canal_LED_BLUE, 0); // Encender el LED si no se encuentra el hardware Ethernet
    ethernetConnected = false;
  } else if (Ethernet.linkStatus() == LinkOFF) {
    Serial.println("Cable ethernet no conectado");
    ledcWrite(canal_LED_RED, 255);
    ledcWrite(canal_LED_GREEN, 0);
    ledcWrite(canal_LED_BLUE, 0); // Encender el LED si el cable Ethernet no está conectado
    ethernetConnected = false;
  } else {
    if (!ethernetConnected) {
      // Intentar reconectar si la conexión se perdió
      if (Ethernet.begin(mac) != 0) {
        Serial.println("Reconectando Ethernet.");
        ethernetConnected = true;
        timeClient.begin();
        timeClient.setTimeOffset(utcOffsetInSeconds);
        ledcWrite(canal_LED_RED, 255);
        ledcWrite(canal_LED_GREEN, 255);
        ledcWrite(canal_LED_BLUE, 255);
      }
    }
  }
}
